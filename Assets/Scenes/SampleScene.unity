--- !u!114 &792998892444503578
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8421041312125933925}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u043E\u0447\u043A\u0430 \u2014 \u043F\u0430\u0440\u043D\u044B\u0439
    \u043E\u0440\u0433\u0430\u043D \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043F\u043E\u0437\u0432\u043E\u043D\u043E\u0447\u043D\u044B\u0445,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u0431\u0430\u043B\u0430\u043D\u0441 \u0432\u043E\u0434\u044B \u0438 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043B\u0438\u0442\u043E\u0432
    \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0435 (\u043E\u0441\u043C\u043E\u0440\u0435\u0433\u0443\u043B\u044F\u0446\u0438\u044E),
    \u0444\u0438\u043B\u044C\u0442\u0440\u0443\u0435\u0442 \u043A\u0440\u043E\u0432\u044C,
    \u0432\u044B\u0432\u043E\u0434\u0438\u0442 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B
    \u043C\u0435\u0442\u0430\u0431\u043E\u043B\u0438\u0437\u043C\u0430, \u0443 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043F\u043E\u0437\u0432\u043E\u043D\u043E\u0447\u043D\u044B\u0445 \u0442\u0430\u043A\u0436\u0435
    \u0432\u044B\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u0433\u043E\u0440\u043C\u043E\u043D\u044B,
    \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u0435\u0442 \u0432 \u0441\u0438\u043D\u0442\u0435\u0437\u0435
    \u0438\u043B\u0438 \u043C\u0435\u0442\u0430\u0431\u043E\u043B\u0438\u0437\u043C\u0435
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0445 \u0432\u0438\u0442\u0430\u043C\u0438\u043D\u043E\u0432
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u043A\u0440\u043E\u0432\u044F\u043D\u043E\u0435 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435.
    \u0424\u0438\u043B\u044C\u0442\u0440\u0443\u044F \u043A\u0440\u043E\u0432\u044C,
    \u043F\u043E\u0447\u043A\u0438 \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0442
    \u043C\u043E\u0447\u0443, \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0438\u0437 \u0432\u043E\u0434\u044B \u0438 \u043B\u0438\u0448\u043D\u0438\u0445
    \u0438\u043B\u0438 \u043D\u0435\u043D\u0443\u0436\u043D\u044B\u0445 \u0432\u0435\u0449\u0435\u0441\u0442\u0432."
