--- !u!114 &2776353827653635843
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 993733471433271053}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0438\u0449\u0435\u0432\u0430\u0440\u0438\u0301\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442, \u0436\u0435\u043B\u0443\u0301\u0434\u043E\u0447\u043D\u043E-\u043A\u0438\u0448\u0435\u0301\u0447\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442 (\u0436\u043A\u0442), \u043F\u0438\u0449\u0435\u0432\u0430\u0301\u044F
    \u0442\u0440\u0443\u0431\u043A\u0430 \u2014 \u043F\u0438\u0449\u0435\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043E\u0440\u0433\u0430\u043D\u043E\u0432
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0445 \u043C\u043D\u043E\u0433\u043E\u043A\u043B\u0435\u0442\u043E\u0447\u043D\u044B\u0445
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445, \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u0430\u044F
    \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u0438 \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0438\u0437
    \u043F\u0438\u0449\u0438 \u043F\u0438\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432, \u0432\u0441\u0430\u0441\u044B\u0432\u0430\u043D\u0438\u044F
    \u0438\u0445 \u0432 \u043A\u0440\u043E\u0432\u044C \u0438 \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0438\u0437 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0430 \u043D\u0435\u043F\u0435\u0440\u0435\u0432\u0430\u0440\u0435\u043D\u043D\u044B\u0445
    \u043E\u0441\u0442\u0430\u0442\u043A\u043E\u0432."
