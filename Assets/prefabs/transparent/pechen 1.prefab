  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0435\u0301\u0447\u0435\u043D\u044C \u2014 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u0430\u044F \u0436\u0435\u043B\u0435\u0437\u0430 \u0432\u043D\u0435\u0448\u043D\u0435\u0439
    \u0441\u0435\u043A\u0440\u0435\u0446\u0438\u0438 \u043F\u043E\u0437\u0432\u043E\u043D\u043E\u0447\u043D\u044B\u0445
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043D\u0430\u0445\u043E\u0434\u044F\u0449\u0430\u044F\u0441\u044F
    \u0432 \u0431\u0440\u044E\u0448\u043D\u043E\u0439 \u043F\u043E\u043B\u043E\u0441\u0442\u0438
    (\u043F\u043E\u043B\u043E\u0441\u0442\u0438 \u0436\u0438\u0432\u043E\u0442\u0430)
    \u043F\u043E\u0434 \u0434\u0438\u0430\u0444\u0440\u0430\u0433\u043C\u043E\u0439
    \u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u044E\u0449\u0430\u044F \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. \u041F\u0435\u0447\u0435\u043D\u044C
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u0430\u043C\u043E\u0439
    \u043A\u0440\u0443\u043F\u043D\u043E\u0439 \u0436\u0435\u043B\u0435\u0437\u043E\u0439
    \u043F\u043E\u0437\u0432\u043E\u043D\u043E\u0447\u043D\u044B\u0445."
