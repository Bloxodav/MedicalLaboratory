  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041B\u0451\u0433\u043A\u0438\u0435 \u2014 \u043E\u0440\u0433\u0430\u043D\u044B
    \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u043E\u0433\u043E \u0434\u044B\u0445\u0430\u043D\u0438\u044F
    \u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0432\u0441\u0435\u0445
    \u043C\u043B\u0435\u043A\u043E\u043F\u0438\u0442\u0430\u044E\u0449\u0438\u0445,
    \u043F\u0442\u0438\u0446, \u043F\u0440\u0435\u0441\u043C\u044B\u043A\u0430\u044E\u0449\u0438\u0445\u0441\u044F,
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430 \u0437\u0435\u043C\u043D\u043E\u0432\u043E\u0434\u043D\u044B\u0445,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0443 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0440\u044B\u0431 (\u0434\u0432\u043E\u044F\u043A\u043E\u0434\u044B\u0448\u0430\u0449\u0438\u0445,
    \u043A\u0438\u0441\u0442\u0435\u043F\u0451\u0440\u044B\u0445 \u0438 \u043C\u043D\u043E\u0433\u043E\u043F\u0451\u0440\u043E\u0432\u044B\u0445).
    \u0412 \u043B\u0451\u0433\u043A\u0438\u0445 \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0433\u0430\u0437\u043E\u043E\u0431\u043C\u0435\u043D \u043C\u0435\u0436\u0434\u0443
    \u0432\u043E\u0437\u0434\u0443\u0445\u043E\u043C, \u043D\u0430\u0445\u043E\u0434\u044F\u0449\u0438\u043C\u0441\u044F
    \u0432 \u043F\u0430\u0440\u0435\u043D\u0445\u0438\u043C\u0435 \u043B\u0451\u0433\u043A\u0438\u0445,
    \u0438 \u043A\u0440\u043E\u0432\u044C\u044E, \u043F\u0440\u043E\u0442\u0435\u043A\u0430\u044E\u0449\u0435\u0439
    \u043F\u043E \u043B\u0451\u0433\u043E\u0447\u043D\u044B\u043C \u043A\u0430\u043F\u0438\u043B\u043B\u044F\u0440\u0430\u043C."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
