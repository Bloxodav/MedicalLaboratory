  m_text: "\u0413\u043B\u0430\u0437 \u2014 \u0441\u0435\u043D\u0441\u043E\u0440\u043D\u044B\u0439
    \u043E\u0440\u0433\u0430\u043D (\u043E\u0440\u0433\u0430\u043D \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B) \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445,
    \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0449\u0438\u0439 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0435
    \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u0435 \u0432 \u0432\u0438\u0434\u0438\u043C\u043E\u043C
    \u0434\u0438\u0430\u043F\u0430\u0437\u043E\u043D\u0435 \u0434\u043B\u0438\u043D
    \u0432\u043E\u043B\u043D \u0438 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044E\u0449\u0438\u0439
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u0437\u0440\u0435\u043D\u0438\u044F.
    \u0423 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0447\u0435\u0440\u0435\u0437
    \u0433\u043B\u0430\u0437 \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u0435\u0442
    \u043E\u043A\u043E\u043B\u043E 80 % \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
